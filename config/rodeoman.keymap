        // =========================================================================
        // --- 2. Ctrl + A (<Key1> + Ctrl + A) ---
        // =========================================================================
        
        // Ctrl + A, A: 回転
        ctrl_a_a: ctrl_a_a {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press &kp LCTRL>
                , <&macro_tap &kp A>, <&macro_release &kp LCTRL>
                , <&macro_tap &kp A>
                ;
        };

        // Ctrl + A, B: 長方形(サイズ)
        ctrl_a_b: ctrl_a_b {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press &kp LCTRL>
                , <&macro_tap &kp A>, <&macro_release &kp LCTRL>
                , <&macro_tap &kp B>
                ;
        };

        // Ctrl + A, C: コピー
        ctrl_a_c: ctrl_a_c {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press &kp LCTRL>
                , <&macro_tap &kp A>, <&macro_release &kp LCTRL>
                , <&macro_tap &kp C>
                ;
        };

        // Ctrl + A, D: 補助線削除
        ctrl_a_d: ctrl_a_d {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press &kp LCTRL>
                , <&macro_tap &kp A>, <&macro_release &kp LCTRL>
                , <&macro_tap &kp D>
                ;
