            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>; // 縺薙％繧貞句挨縺ｫ險ｭ螳・
            bindings = <&kp>, <&kp>;
        };
        // 迚ｹ螳壹・繧ｭ繝ｼ逕ｨ縺ｮ遏ｭ縺・愛螳壽凾髢難ｼ井ｾ・ 170ms・・
