        int5_g: int5_g { // 端点再設定(AHK)
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press &kp INT5>
                , <&macro_wait_time 40>
                , <&macro_tap &kp G>
                , <&macro_wait_time 40>
                , <&macro_release &kp INT5>
                ;
        };	
        exl_fill: excel_fill_menu { // Excelのフィルター
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <30>;
            tap-ms = <30>;
            bindings
                = <&macro_tap &kp LALT>
                , <&macro_tap &kp E &kp I &kp S>;
            // ここで止まるので、設定を確認して手動でEnter
        };
        alt_int4: alt_int4 { // Alt+変換 選択位置移動(複写)(AHK)
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp RALT>
                , <&macro_tap     &kp INT4>
                , <&macro_release &kp RALT>
                ;
        };	
        alt_int5: alt_int5 { // Alt+無変換 選択位置移動(移動)(AHK)
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp RALT>
                , <&macro_tap     &kp INT5>
                , <&macro_release &kp RALT>
                ;
        };
        LGUI_LCTRL: LGUI_LCTRL {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LGUI>, <&kp LCTRL>;
        };
        win_right: win_right { // デスクトップ移動進む
            compatible = "zmk,behavior-macro";
            wait-ms = <40>;
            tap-ms = <40>;
            #binding-cells = <0>;
            bindings
                = <&macro_press &kp LGUI>
                , <&macro_press &kp LCTRL>
                , <&macro_tap &kp RIGHT>
                , <&macro_release &kp LCTRL>
                , <&macro_release &kp LGUI>
                ;
        };
        win_left: win_left { // デスクトップ移動戻る
            compatible = "zmk,behavior-macro";
            wait-ms = <40>;
            tap-ms = <40>;
            #binding-cells = <0>;
            bindings
                = <&macro_press &kp LGUI>
                , <&macro_press &kp LCTRL>
                , <&macro_tap &kp LEFT>
                , <&macro_release &kp LCTRL>
                , <&macro_release &kp LGUI>
                ;
        };
        // macro_INT2: macro_INT2 {
        //     compatible = "zmk,behavior-macro";
        //     label = "macro_INT2";
        //     #binding-cells = <0>;
        //     bindings = <&kp INT2>, <&to WIN>;
        // };
        // macro_INT5: macro_INT5 {
        //     compatible = "zmk,behavior-macro";
        //     label = "macro_INT5";
        //     #binding-cells = <0>;
        //     bindings = <&kp INT5>, <&to QWE>;
