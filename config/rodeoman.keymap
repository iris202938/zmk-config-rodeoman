        // macro_LANG1: macro_LANG1 {
        //     compatible = "zmk,behavior-macro";
        //     label = "macro_LANG1";
        //     #binding-cells = <0>;
        //     bindings = <&kp LANG1>, <&to WIN>;
        // };
        // macro_LANG2: macro_LANG2 {
        //     compatible = "zmk,behavior-macro";
        //     label = "macro_LANG2";
        //     #binding-cells = <0>;
        //     bindings = <&kp LANG2>, <&to QWE>;
        // };
        // タップ時の動作: 指定レイヤーへ移動し、LANG1を送信
        // LANG1用のマクロ
        t_lang1: t_lang1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&to NIC &kp LANG1>; // レイヤー2（NIC）に戻る
        };
        t_lang2: t_lang2 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&to QWE &kp LANG2>; // レイヤー0（QWE）に戻る
        };
        t_eint2: t_eint2 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp ESC &kp INT2>;
        };
        t_int4: t_int4 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&to NICL &kp INT4 &kp LANG1>; // レイヤー5（NICL）に戻る
        };
        t_int5: t_int5 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <10>; // 全体の基本遅延
            tap-ms = <10>;
            bindings 
                = <&to LIN> // レイヤー3（LIN）に戻る
                , <&macro_wait_time 20> // ここで20ミリ秒待機
                , <&kp  INT5>
                , <&kp  LANG2>;
        };
        tW_int4: tW_int4 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&to WIN &kp INT4 &kp LANG1>; // レイヤー7（WIN）に戻る
        };
        tC_int5: tC_int5 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <10>; // 全体の基本遅延
            tap-ms = <10>;
            bindings 
                = <&to CAD> // レイヤー6（CAD）に戻る
                , <&macro_wait_time 30> // ここで30ミリ秒待機
                , <&kp  INT5>
                , <&kp  LANG2>;
        };
        bt0_lQWE: bt0_lQWE { // Bluetoothプロファイル0を選択し、レイヤーQWEを有効化
