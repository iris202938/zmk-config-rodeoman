        // =========================================================================
        // --- 2. Ctrl + A (<Key1> + Ctrl + A) ---
        // =========================================================================
        
        // Ctrl + A, A: 蝗櫁ｻ｢
        ctrl_a_a: ctrl_a_a {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press &kp LCTRL>
                , <&macro_tap &kp A>, <&macro_release &kp LCTRL>
                , <&macro_tap &kp A>
                ;
        };

        // Ctrl + A, B: 髟ｷ譁ｹ蠖｢(繧ｵ繧､繧ｺ)
        ctrl_a_b: ctrl_a_b {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press &kp LCTRL>
                , <&macro_tap &kp A>, <&macro_release &kp LCTRL>
                , <&macro_tap &kp B>
                ;
        };

        // Ctrl + A, C: 繧ｳ繝斐・
        ctrl_a_c: ctrl_a_c {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press &kp LCTRL>
                , <&macro_tap &kp A>, <&macro_release &kp LCTRL>
                , <&macro_tap &kp C>
                ;
        };

