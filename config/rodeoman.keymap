            bindings = <&exl_fill>;
        };
		combo_m_xl_rename { // Excelのシート名変更マクロ
			timeout-ms = <80>;
        	key-positions = <15 8 3>; // H,O,Rのキー位置に書き換えてください
			layers = <QWE LIN CAD RSE RSEL RSEW>;
            bindings = <&m_xl_rename>;
        };
        combo_ADJ_ss1 { // ADJレイヤーでのスクリーンショット1
