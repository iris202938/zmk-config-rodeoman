            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp ESC &kp INT2>;
        };
        t_int4: t_int4 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&to NICL &kp INT4 &kp LANG1>; // 繝ｬ繧､繝､繝ｼ5・・ICL・峨↓謌ｻ繧・
        };
        t_int5: t_int5 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <10>; // 蜈ｨ菴薙・蝓ｺ譛ｬ驕・ｻｶ
            tap-ms = <10>;
            bindings 
                = <&to LIN> // 繝ｬ繧､繝､繝ｼ3・・IN・峨↓謌ｻ繧・
                , <&macro_wait_time 20> // 縺薙％縺ｧ20繝溘Μ遘貞ｾ・ｩ・
                , <&kp  INT5>
                , <&kp  LANG2>;
        };
        tW_int4: tW_int4 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&to WIN &kp INT4 &kp LANG1>; // 繝ｬ繧､繝､繝ｼ7・・IN・峨↓謌ｻ繧・
        };
