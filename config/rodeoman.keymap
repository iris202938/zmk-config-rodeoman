        // Ctrl + A, E: 譁・ｭ礼ｨｮ蛻･螟画峩
        ctrl_a_e: ctrl_a_e {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press &kp LCTRL>
                , <&macro_tap &kp A>, <&macro_release &kp LCTRL>
                , <&macro_tap &kp E>
                ;
        };

        // Ctrl + A, F: 螟夂嶌邨千ｷ・
        ctrl_a_f: ctrl_a_f {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press &kp LCTRL>
                , <&macro_tap &kp A>, <&macro_release &kp LCTRL>
