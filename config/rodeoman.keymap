        // LANG1逕ｨ縺ｮ繝槭け繝ｭ
        t_lang1: t_lang1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&to NIC &kp LANG1>; // 繝ｬ繧､繝､繝ｼ2・・IC・峨↓謌ｻ繧・
        };
        t_lang2: t_lang2 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&to QWE &kp LANG2>; // 繝ｬ繧､繝､繝ｼ0・・WE・峨↓謌ｻ繧・
        };
