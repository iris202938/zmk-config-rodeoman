    behaviors {
        // LANG1用のHold-Tap: ホールドで指定Layer, タップでマクロ(t_lang1)
        ht_lg1: ht_lg1 {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <150>;
            bindings = <&mo>, <&t_lang1>;
        };
        // LANG2用のHold-Tap: ホールドで指定Layer, タップでマクロ(t_lang2)
