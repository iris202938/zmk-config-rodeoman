        lt_bl: lt_balanced {
            compatible = "zmk,behavior-hold-tap";
            label = "LT_BALANCED";
            #binding-cells = <2>;
            tapping-term-ms = <190>;
            flavor = "balanced";  // 他のキーがタップされたら即座にNUMレイヤーを確定
            bindings = <&mo>, <&kp>;
        };

        // A-Z共通のHold-Tap定義
        all_ht: all_hold_tap {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <230>; // タップダンスのタイムアウトと同じに設定
            quick-tap-ms = <0>;
            bindings = <&kp>, <&kp>;
        };

        // --- Tap Dance A ---
        td_A: tap_dance_A {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <230>;
