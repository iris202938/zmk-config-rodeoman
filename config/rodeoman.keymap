        // --- Tap Dance SEMICOLON ---
        td_SEMI: tap_dance_SEMI {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <230>;
            // 1-Tap: 騾壼ｸｸ繧ｭ繝ｼ, 2-Taps: 0.5mm , 3-Taps: 0.25mm
            bindings = <&all_ht RCTRL SEMI>, <&ctrl_alt_l>, <&ctrl_alt_semi>; 
        };

        // --- Tap Dance COMMA ---
        td_COMMA: tap_dance_COMMA {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <230>;
            // 1-Tap: 騾壼ｸｸ繧ｭ繝ｼ, 2-Taps: 驫俶攸陦ｨ邱ｨ髮・(Ctrl+F+c), 3-Taps:  驫俶攸陦ｨ (Ctrl+F+d)
            bindings = <&all_ht COMMA COMMA>, <&ctrl_f_c>, <&ctrl_f_d>;
        };

        // --- Tap Dance DOT ---
        td_DOT: tap_dance_DOT {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <230>;
            // 1-Tap: 騾壼ｸｸ繧ｭ繝ｼ, 2-Taps: 驛ｨ蜩∬｡ｨ邱ｨ髮・(Ctrl+F+g), 3-Taps:  髮・ｨ郁｡ｨ (Ctrl+F+h)
            bindings = <&all_ht DOT DOT>, <&ctrl_f_g>, <&ctrl_f_h>;
        };

        // --- Tap Dance SLASH ---
        td_SLASH: tap_dance_SLASH {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <230>;
            // 1-Tap: 騾壼ｸｸ繧ｭ繝ｼ, 2-Taps: 1G , 3-Taps: 1/4G
            bindings = <&all_ht RGUI SLASH>, <&ctrl_alt_j>, <&ctrl_alt_k>;
        };

        // 騾壼ｸｸ縺ｮ蛻､螳壽凾髢難ｼ井ｾ・ 240ms・・
        mt_s: mod_tap_slow {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <240>;
            bindings = <&kp>, <&kp>;
        };
        // 迚ｹ螳壹・繧ｭ繝ｼ逕ｨ縺ｮ遏ｭ縺・愛螳壽凾髢難ｼ井ｾ・ 200ms・・
