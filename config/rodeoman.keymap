        lt_bl: lt_balanced {
            compatible = "zmk,behavior-hold-tap";
            label = "LT_BALANCED";
            #binding-cells = <2>;
            tapping-term-ms = <190>;
            flavor = "balanced";  // 莉悶・繧ｭ繝ｼ縺後ち繝・・縺輔ｌ縺溘ｉ蜊ｳ蠎ｧ縺ｫNUM繝ｬ繧､繝､繝ｼ繧堤｢ｺ螳・
            bindings = <&mo>, <&kp>;
        };

        // A-Z蜈ｱ騾壹・Hold-Tap螳夂ｾｩ
        all_ht: all_hold_tap {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <230>; // 繧ｿ繝・・繝繝ｳ繧ｹ縺ｮ繧ｿ繧､繝繧｢繧ｦ繝医→蜷後§縺ｫ險ｭ螳・
            quick-tap-ms = <0>;
            bindings = <&kp>, <&kp>;
        };

        // --- Tap Dance A ---
        td_A: tap_dance_A {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <230>;
            bindings = <&all_ht LCTRL A>, <&ctrl_a_a>, <&ctrl_d_a>, <&ctrl_f_a>;
        };

