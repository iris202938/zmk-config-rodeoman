        // --- Tap Dance W ---
        td_W: tap_dance_W {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <230>;
            bindings = <&all_ht W W>, <&ctrl_a_w>, <&ctrl_d_w>, <&ctrl_f_w>;
        };

        // --- Tap Dance X ---
        td_X: tap_dance_X {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <230>;
            bindings = <&all_ht X X>, <&ctrl_a_x>, <&ctrl_d_x>, <&ctrl_f_x>;
        };

        // --- Tap Dance Y ---
        td_Y: tap_dance_Y {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <230>;
            bindings = <&all_ht Y Y>, <&ctrl_a_y>, <&ctrl_d_y>, <&ctrl_f_y>;
        };

        // --- Tap Dance Z ---
        td_Z: tap_dance_Z {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <230>;
            bindings = <&all_ht LALT Z>, <&ctrl_a_z>, <&ctrl_d_z>, <&ctrl_f_z>;
        };

        // --- Tap Dance SEMICOLON ---
        td_SEMI: tap_dance_SEMI {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <230>;
            // 1-Tap: 通常キー, 2-Taps: 0.5mm , 3-Taps: 0.25mm
            bindings = <&all_ht RCTRL SEMI>, <&ctrl_alt_l>, <&ctrl_alt_semi>; 
        };

        // --- Tap Dance COMMA ---
        td_COMMA: tap_dance_COMMA {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <230>;
            // 1-Tap: 通常キー, 2-Taps: 銘板表編集 (Ctrl+F+c), 3-Taps:  銘板表 (Ctrl+F+d)
            bindings = <&all_ht COMMA COMMA>, <&ctrl_f_c>, <&ctrl_f_d>;
        };

        // --- Tap Dance DOT ---
        td_DOT: tap_dance_DOT {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <230>;
            // 1-Tap: 通常キー, 2-Taps: 部品表編集 (Ctrl+F+g), 3-Taps:  集計表 (Ctrl+F+h)
            bindings = <&all_ht DOT DOT>, <&ctrl_f_g>, <&ctrl_f_h>;
        };

        // --- Tap Dance SLASH ---
        td_SLASH: tap_dance_SLASH {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <230>;
            // 1-Tap: 通常キー, 2-Taps: 1G , 3-Taps: 1/4G
            bindings = <&all_ht RGUI SLASH>, <&ctrl_alt_j>, <&ctrl_alt_k>;
        };
        
        // 通常の判定時間（例: 240ms）
        mt_s: mod_tap_slow {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <240>;
            bindings = <&kp>, <&kp>;
        };
        // 特定のキー用の短い判定時間（例: 200ms）
        mt_m: mod_tap_mid {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>; // ここを個別に設定
            bindings = <&kp>, <&kp>;
        };
        // 特定のキー用の短い判定時間（例: 170ms）
        mt_f: mod_tap_fast {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <170>; // ここを個別に設定
            bindings = <&kp>, <&kp>;
        };
    };

