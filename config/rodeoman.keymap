        // Ctrl + A, H: 譁・ｭ怜・鄂ｮ謠・
        ctrl_a_h: ctrl_a_h {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press &kp LCTRL>
                , <&macro_tap &kp A>, <&macro_release &kp LCTRL>
                , <&macro_tap &kp H>
                ;
        };

        // Ctrl + A, I: 騾｣邯壼ｯｸ豕慕ｷ・
        ctrl_a_i: ctrl_a_i {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press &kp LCTRL>
